<mvc:View controllerName="com.cpg.master.master.controller.View1"
 xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout" 
	xmlns:u="sap.ui.unified"
	xmlns:core="sap.ui.core"
	xmlns:mdc="sap.ui.mdc"
	xmlns:mdct="sap.ui.mdc.table"
	xmlns:vm="sap.ui.fl.variants"
	xmlns:upload="sap.m.upload"
	xmlns:mdcat="sap.ui.mdc.actiontoolbar">

    	<SplitApp
		id="SplitAppDemo"
		initialDetail="detail"
		initialMaster="master">
		<detailPages>
	<Page title = "Header Details">
	
<Table id="idTable">
		<!-- items="{}"> -->

			<columns>
            <Column
				width="12em">
				<Text text="EBELN" />
			</Column>
			<Column
				width="12em">
				<Text text="EBELP" />
			</Column>
			<Column
				width="12em">
				<Text text="MATNR" />
			</Column>

			<Column
				width="12em">
				<Text text="BUKRS" />
			</Column>
            <Column
				width="12em">
				<Text text="WERKS" />
			</Column>
		    </columns>	
        <items>
			<ColumnListItem vAlign="Middle">
				<cells>
		         <Input value="{FormModel>/EBELN}" ></Input>
				 <Input value="{FormModel>/EBELP}" />
				<Input value="{FormModel>/MATNR}" />
				 <Input value="{FormModel>/BUKRS}" />
                  <Input value="{FormModel>/WERKS}" />



		 	    </cells>
			</ColumnListItem>
		</items>
     </Table>





<IconTabBar id="idIconTabBarMulti" expanded="{device>/isNoPhone}" class="sapUiResponsiveContentPadding">
<items>
<IconTabFilter icon="sap-icon://hint" key="info">

<Table id="idTable1">
		<!-- items="{FormModel>/HeadertoItemNP/results/0}"> -->

			<columns>
            <Column
				width="12em">
				<Text text="EBELN" />
			</Column>
			<Column
				width="12em">
				<Text text="FLAG" />
			</Column>
			<Column
				width="12em">
				<Text text="MESSAGE" />
			</Column>
<!-- 
			<Column
				width="12em">
				<Text text="BUKRS" />
			</Column>
            <Column
				width="12em">
				<Text text="WERKS" />
			</Column> -->
		    </columns>	
        <items>
			<ColumnListItem vAlign="Middle">
				<cells>
		         <Input value="{FormModel>/HeadertoItemNP/results/0/EBELN}" ></Input>
				 <Input value="{FormModel>/HeadertoItemNP/results/0/FLAG}" />
				<Input value="{FormModel>/HeadertoItemNP/results/0/MESSAGE}" />
				 <!-- <Input value="{FormModel>/BUKRS}" />
                  <Input value="{FormModel>/WERKS}" /> -->



		 	    </cells>
			</ColumnListItem>
		</items>
     </Table>



</IconTabFilter>
<IconTabFilter icon="sap-icon://attachment" key="attachments" count="3">
<Text text="Attachments go here ..."/>
<l:VerticalLayout>
<u:FileUploader id="fileUploader" name="myFileUpload" uploadUrl="upload/" tooltip="Upload your file to the local server" uploadComplete="handleUploadComplete"/>
<Button text="Upload File" press="handleUploadPress"/>
</l:VerticalLayout>
</IconTabFilter>
<IconTabFilter icon="sap-icon://notes" key="notes"  count="12">
	

</IconTabFilter>
<IconTabFilter icon="sap-icon://group" key="people">
<Text text="People content goes here ..."/>
</IconTabFilter>
</items>
</IconTabBar>
 

	
    	<footer>
			<OverflowToolbar>
				<ToolbarSpacer/>
				<Button text="Accept" type="Accept" press="OnApprove" />
				<Button text="Reject" type="Reject" press="OnReject" />

			</OverflowToolbar>
		</footer>
			</Page>

	
		</detailPages>
        	<masterPages>
		
			<Page
				title="Master Details">
        <SearchField width="100%" search=".onSearch" />
        <List  items="{MasterModel>/}" id="Master"
		headerText="">

		<StandardListItem
           	type="Navigation" 
			title="{MasterModel>EBELN}"
			description="{MasterModel>ERNAM}" 
            press="onMasterPress"
            info="{MasterModel>AEDAT}"/>
           
	</List>

			</Page>
		</masterPages>
	</SplitApp>
</mvc:View>